# =====================================================
# RecTrack — plantilla de variables de entorno
#
# Copia este archivo a .env.local y rellena los valores:
#   cp .env.example .env.local
#
# .env.local NO se versiona (ver .gitignore). docker-compose.yml
# lo carga en el contenedor vía env_file.
# =====================================================

# Contraseña del panel admin (la que escribes al iniciar sesión).
# Obligatoria — la API admin falla en runtime si no está definida.
ADMIN_PASSWORD=cambia-esta-contrasena

# Clave para firmar los tokens de sesión (HMAC). Obligatoria.
# Genera un valor aleatorio de 64 caracteres hexadecimales con cualquiera
# de estos comandos (usa el que tengas disponible):
#   openssl rand -hex 32
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=genera-un-token-hex-de-64-caracteres

# Orígenes permitidos para CORS del panel externo (lista separada por comas).
# Opcional. Sin definir → "*" (wildcard).
# En local deja esta línea comentada; en producción pon la URL exacta del panel.
# ADMIN_PANEL_ORIGIN=https://panel.tu-dominio.com
